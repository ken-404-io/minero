# Prisma / SQLite
# For development: relative path (Prisma CLI resolves this relative to the project root)
DATABASE_URL="file:./dev.db"

# For the Next.js app (PrismaLibSql adapter needs file:// absolute path at runtime)
# This is overridden in .env.local with the absolute path
DATABASE_URL_RUNTIME="file:///home/user/minero/dev.db"

# JWT secret - CHANGE THIS IN PRODUCTION (min 32 characters)
JWT_SECRET="minero-dev-secret-change-in-production-32c"
