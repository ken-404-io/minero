# Neon Postgres (pooled URL recommended for serverless; direct URL for migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Optional: unpooled URL for running `prisma migrate`.
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# JWT signing secret. Generate with: openssl rand -base64 48
JWT_SECRET="replace-me-with-a-long-random-string-min-32-chars"

# HTTP server
PORT=4000
NODE_ENV=development

# CORS: comma-separated list of allowed frontend origins (no trailing slash).
FRONTEND_ORIGIN="http://localhost:3000"

# Cookie domain for cross-site session cookies. Leave blank for localhost.
# In production set to the parent domain shared by frontend + backend, e.g. ".example.com".
COOKIE_DOMAIN=""

# -----------------------------------------------------------------------------
# Third-party sign-in (optional). Leave blank to hide provider buttons.
#
# The OAuth callback URL is <OAUTH_REDIRECT_BASE>/auth/oauth/<provider>/callback.
# Add that exact URL to your Google/Facebook app's authorized redirect list.
# -----------------------------------------------------------------------------
OAUTH_REDIRECT_BASE="http://localhost:4000"

# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook — https://developers.facebook.com/apps
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# GitHub — https://github.com/settings/developers (OAuth Apps)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# PayMongo — ₱49 activation checkout (GCash / Maya / card).
# Dashboard: https://dashboard.paymongo.com/developers
#
# Register a webhook pointing at POST <backend>/payments/webhook subscribed to
# the "checkout_session.payment.paid" event. Copy the resulting whsec_… value
# into PAYMONGO_WEBHOOK_SECRET.
# -----------------------------------------------------------------------------
PAYMONGO_SECRET_KEY="sk_test_replace_me"
PAYMONGO_WEBHOOK_SECRET="whsec_replace_me"

# Public base URL of the frontend. Used to build success_url / cancel_url when
# creating PayMongo Checkout Sessions (e.g. https://yourdomain.com).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Email — Resend. Leave RESEND_API_KEY blank to log emails to the console.
# https://resend.com/
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Minero <noreply@minero.app>"

# -----------------------------------------------------------------------------
# SMS OTP provider.
#
# SMS_PROVIDER controls which driver is used. Leave blank (or set to "console")
# to log OTP codes to the server log — suitable for local development.
#
# "semaphore" — recommended for Philippine numbers (09XXXXXXXXX). Get a key at
#   https://semaphore.co/. Sender name must be registered or use SEMAPHORE.
# "twilio"    — global fallback. E.164 numbers only; PH 09… is normalised to
#   +63… before send. Get credentials at https://www.twilio.com/.
# -----------------------------------------------------------------------------
SMS_PROVIDER=""

SEMAPHORE_API_KEY=""
SEMAPHORE_SENDER_NAME="MINERO"

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# -----------------------------------------------------------------------------
# Async job queue (pg-boss). Jobs run in the same Postgres as the app; no
# extra infra required. Set QUEUE_DISABLED=true to run all side-effects
# synchronously (useful for tests).
#
# pg-boss uses LISTEN/NOTIFY + advisory locks, which don't work reliably
# through pgbouncer transaction-mode poolers. If DATABASE_URL_UNPOOLED is
# set, the queue uses it; otherwise it falls back to DATABASE_URL.
# -----------------------------------------------------------------------------
QUEUE_DISABLED=""
