# Public URL of the backend API (exposed to the browser).
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Server-side URL (can differ if backend is reachable at a different hostname
# from the Next.js server, e.g. inside a private network). Falls back to
# NEXT_PUBLIC_API_URL when unset.
API_URL_INTERNAL=""

# Public URL of this frontend — used by the backend to build PayMongo
# success_url / cancel_url. Must match the origin users actually visit.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
